NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=debug

API_PREFIX=/api
API_VERSION=v1
API_KEY_ENABLED=false
API_KEY=

APP_NAME=assessment-image-storage-service
APP_DESCRIPTION=Microservice for uploading, serving, and deleting product image files

ENABLE_SWAGGER=true
ENABLE_HEALTH_CHECK=true

VOLUME_MOUNT_PATH=/data/images
MAX_FILE_SIZE_MB=10
MAX_IMAGES_PER_PRODUCT=20

CORS_ENABLED=true
CORS_ORIGIN=*
